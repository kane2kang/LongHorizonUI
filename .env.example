# ─────────────────────────────────────────
# LongHorizonUI 环境变量配置
# 仅需配置你使用的 LLM 提供商，其余留空即可
# ─────────────────────────────────────────

# --- LLM Provider (Gemini 推荐) ---
LLM_PROJECT=
LLM_LOCATION=
LLM_KEY_PATH=
LLM_API_KEY=
LLM_MODEL=gemini-2.5-pro

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# --- OpenAI ---
OPENAI_ENDPOINT=https://api.openai.com/v1
OPENAI_API_KEY=

# --- 感知模块（可选） ---
# 如有预定义的图标模板目录，填写路径
ICON_TEMPLATE_DIR=